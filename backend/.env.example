DATABASE_URL=postgresql+asyncpg://onboarding:onboarding@localhost:5433/onboarding
MAX_UPLOAD_BYTES=5242880
CORS_ORIGINS=http://localhost:5173

# AWS — required. The app will not start without these.
AWS_REGION=us-east-1
AWS_S3_BUCKET=onboarding-agent-docs
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
PRESIGNED_URL_TTL_SECONDS=300

# Cognito — required for /api/auth/* endpoints
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=

# OpenSanctions — Stage 3 sanctions + PEP screening.
# Leave OPENSANCTIONS_API_KEY blank to run screening in dev stub mode.
OPENSANCTIONS_API_KEY=
OPENSANCTIONS_BASE_URL=https://api.opensanctions.org
OPENSANCTIONS_DATASET=default
OPENSANCTIONS_SCORE_THRESHOLD=0.7
OPENSANCTIONS_TIMEOUT_S=10.0
